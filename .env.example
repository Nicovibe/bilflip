# =============================================================================
# bilvipp — required environment variables
# =============================================================================
# Copy to .env.local for development. In production, set these via the Vercel
# dashboard (Settings → Environment Variables) or `vercel env add`.
#
# IMPORTANT: never commit .env.local. .gitignore already covers it.

# -----------------------------------------------------------------------------
# Auth.js v5
# -----------------------------------------------------------------------------
# Generate once with: openssl rand -base64 32
# This signs/encrypts session JWTs. Rotating it logs everyone out.
AUTH_SECRET=

# Auto-set on Vercel; only needed for local dev. Don't include trailing slash.
# In production Auth.js infers the URL from request headers.
AUTH_URL=http://localhost:3000

# Optional: required only for non-Vercel hosts behind a proxy.
# AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Resend (magic-link emails)
# -----------------------------------------------------------------------------
# Sign up: https://resend.com — create API key with `Sending` scope.
# The from-address must be on a domain you've verified in Resend.
AUTH_RESEND_KEY=re_...
AUTH_EMAIL_FROM=no-reply@bilvipp.no

# -----------------------------------------------------------------------------
# Neon Postgres
# -----------------------------------------------------------------------------
# Vercel Marketplace → Neon → "Connect to Project" auto-injects DATABASE_URL.
# For local dev, copy from the Neon dashboard. Use a separate branch for dev.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Dashboard → Developers → API keys.
# Use sk_test_... for development; sk_live_... only on production.
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Developers → Webhooks → "Add endpoint" with these events:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed
# Endpoint URL (production):  https://<your-domain>/api/billing/webhook
# Endpoint URL (local):       use `stripe listen --forward-to localhost:3000/api/billing/webhook`
#                              and copy the printed `whsec_...` here.
STRIPE_WEBHOOK_SECRET=whsec_...

# Dashboard → Products → create "Pro" and "Trader" recurring products.
# Then copy the Price IDs (price_...) from each product.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TRADER=price_...
